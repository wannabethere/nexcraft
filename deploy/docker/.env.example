# Used by deploy/docker/docker-compose.yml — copy to .env next to that file.
COMPOSE_PROJECT_NAME=nexcraft-temporal

POSTGRESQL_VERSION=16
TEMPORAL_VERSION=1.29.1
TEMPORAL_UI_VERSION=2.34.0

POSTGRES_PASSWORD=temporal
POSTGRES_USER=temporal

# Nexcraft worker → Temporal frontend (Docker DNS service name)
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=nexcraft-recipes
# Must match the worker volume mount path in docker-compose.yml
NEXCRAFT_STAGING_ROOT=/var/lib/nexcraft/staging
