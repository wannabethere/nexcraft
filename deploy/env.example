# Copy to .env in repo root or export before running workers / examples.
# See deploy/README.md for Standalone vs Docker vs Kubernetes.

# --- Temporal (nexcraft-jobs) ---
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=nexcraft-recipes

# Staged workflow extract path (must be visible to all workers)
NEXCRAFT_STAGING_ROOT=/tmp/nexcraft-staging

# --- External databases (examples / your FedSQLClient wiring) ---
# PG_PROD_PASSWORD=
# SF_PASSWORD=
