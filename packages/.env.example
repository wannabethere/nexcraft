# Nexcraft packages — environment template
#
# Copy to a local `.env` (never commit secrets):
#   cp packages/.env.example .env
#
# Load before running CLI / workers / tests:
#   set -a && source .env && set +a
#
# YAML configs expand ${VAR} and ${VAR:-default} at load time.
# ontology-pipeline does NOT auto-load dotenv — you must export vars yourself.


# =============================================================================
# LLM — chat (DeepSeek V3 default, OpenAI-compatible API)
# Used by: ontology-pipeline, ontology-foundry, ontology-retrieval (--with-llm-judge)
# =============================================================================
DEEPSEEK_API_KEY=sk-b77bb7176e6f4aa7be00918d56a9c98e
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Override chat model (default: deepseek-chat). Alternatives: deepseek-reasoner
LLM_MODEL=deepseek-chat

# Optional: use OpenAI for chat instead — set llm.api_key_env: OPENAI_API_KEY in YAML
OPENAI_API_KEY=


# =============================================================================
# Embeddings (DeepSeek has no embedding API — use OpenAI or compatible provider)
# Used by: ontology-store vector indexer, ontology-retrieval Qdrant sources
# =============================================================================
# EMBEDDING_API_KEY=          # falls back to OPENAI_API_KEY when unset
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small


# =============================================================================
# Ontology store (Postgres hierarchy DB)
# Used by: ontology-store, ontology-pipeline (output.kind hierarchy_store|tee),
#          ontology-retrieval API, alembic migrations
# =============================================================================
ONTOLOGY_STORE_URL=postgresql+psycopg://user:password@localhost:5432/ontology_store

# Integration / DAO tests only (optional)
# ONTOLOGY_STORE_TEST_URL=postgresql+psycopg://user@localhost/ontology_test


# =============================================================================
# Pipeline YAML — Postgres source credentials (${VAR} in configs/*.yaml)
# =============================================================================
# configs/example.yaml
PG_USER=
PG_PASSWORD=

# configs/csod_temporal_job.example.yaml
CSOD_PG_USER=
CSOD_PG_PASSWORD=


# =============================================================================
# Qdrant (vector search / reindex)
# Used by: ontology-store CLI, ontology-retrieval vector sources
# =============================================================================
QDRANT_URL=http://localhost:6333
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_API_KEY=

# Live vector tests only (optional)
# QDRANT_TEST_URL=http://localhost:6333


# =============================================================================
# Temporal (orchestration)
# Used by: ontology-pipeline temporal worker, nexcraft-jobs YAML submitter
# =============================================================================
TEMPORAL_TARGET=localhost:7233
TEMPORAL_NAMESPACE=default
ONTOLOGY_PIPELINE_TASK_QUEUE=ontology-pipeline-default
TEMPORAL_TASK_QUEUE=nexcraft-recipes

# Enable ontology-pipeline Temporal integration tests (optional)
# RUN_TEMPORAL_TESTS=1


# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO


# =============================================================================
# Nexcraft driver (gRPC FedSQL gateway — optional)
# =============================================================================
NEXCRAFT_DRIVER_HOST=0.0.0.0
NEXCRAFT_DRIVER_PORT=50051
NEXCRAFT_DRIVER_SPOOL=_async_results
NEXCRAFT_DRIVER_LOG_LEVEL=INFO
# NEXCRAFT_DRIVER_INSECURE=1
# NEXCRAFT_DRIVER_TOKENS=token1,token2


# =============================================================================
# Nexcraft jobs — staging / Docker worker
# =============================================================================
NEXCRAFT_STAGING_ROOT=/var/lib/nexcraft/staging


# =============================================================================
# Nexcraft jobs — SQL Server / CSOD multihop examples (${CSOD_*})
# =============================================================================
CSOD_SERVER=
CSOD_DATABASE=
CSOD_UID=
CSOD_PWD=


# =============================================================================
# Nexcraft jobs — Postgres (Cornerstone / generic examples)
# =============================================================================
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSL_MODE=require
# POSTGRES_CONNECT_TIMEOUT=30

CORNERSTONE_TABLE=public.transcript_csod
CORNERSTONE_SCORE_COL=score
CORNERSTONE_TIME_COL=completiondate
CORNERSTONE_STATUS_COL=trainingstatus
CORNERSTONE_USER_COL=userid
CORNERSTONE_ACTIVITY_COL=loid
CORNERSTONE_SAMPLE_ROWS=100000


# =============================================================================
# Nexcraft jobs — Snowflake (PriceMedic example)
# =============================================================================
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_PASSWORD=
# SNOWFLAKE_PRIVATE_KEY_PATH=
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
# SNOWFLAKE_AUTHENTICATOR=externalbrowser
# SNOWFLAKE_ROLE=

PRICEMEDIC_TABLE=
PRICEMEDIC_RATE_COL=NEGOTIATED_RATE
PRICEMEDIC_DATE_COL=EFFECTIVE_DATE
PRICEMEDIC_HOSPITAL_COL=HOSPITAL_NAME
PRICEMEDIC_PROCEDURE_COL=CPT_CODE
PRICEMEDIC_PAYER_COL=PAYER_NAME
PRICEMEDIC_SAMPLE_ROWS=500000


# =============================================================================
# Nexcraft jobs — AWS S3 (Delta Lake / Iceberg via DuckDB)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# AWS_SESSION_TOKEN=
# AWS_PROFILE=

DELTA_TABLE_S3_PATH=
DELTA_RATE_COL=metric_val
DELTA_DATE_COL=metric_ts
DELTA_GROUP_COL=entity_id
DELTA_SAMPLE_ROWS=10000

ICEBERG_TABLE_S3_PATH=
ICEBERG_RATE_COL=metric_val
ICEBERG_DATE_COL=metric_ts
ICEBERG_GROUP_COL=entity_id
ICEBERG_SAMPLE_ROWS=10000


# =============================================================================
# DuckDB / Arrow (optional tuning for cross-source recipes)
# =============================================================================
# ACERO_ALIGNMENT_HANDLING=reallocate


# =============================================================================
# Docker Compose (deploy/docker — copy to deploy/docker/.env separately)
# =============================================================================
# COMPOSE_PROJECT_NAME=nexcraft-temporal
# POSTGRESQL_VERSION=16
# TEMPORAL_VERSION=1.29.1
# TEMPORAL_UI_VERSION=2.34.0
# POSTGRES_USER=temporal
# POSTGRES_PASSWORD=temporal
# TEMPORAL_HOST=temporal:7233
