# Snowflake connection (required for integration tests + the PriceMedic example).
# Copy this file to `.env`, fill in your values, and source it before running:
#   set -a; source .env; set +a; python examples/snowflake_pricemedic.py
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_WAREHOUSE=

# Optional. Set one of: password, private-key file, or external authenticator.
SNOWFLAKE_PASSWORD=
# SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
# SNOWFLAKE_AUTHENTICATOR=externalbrowser
# SNOWFLAKE_ROLE=

# PriceMedic table + column mapping. Adjust to match your shared listing.
# The fully qualified table name (DB.SCHEMA.TABLE) or a view name.
PRICEMEDIC_TABLE=
# Numeric column for the negotiated rate / price.
PRICEMEDIC_RATE_COL=NEGOTIATED_RATE
# Timestamp / date column for time-series analysis.
PRICEMEDIC_DATE_COL=EFFECTIVE_DATE
# Categorical dimensions used for grouping and pivoting.
PRICEMEDIC_HOSPITAL_COL=HOSPITAL_NAME
PRICEMEDIC_PROCEDURE_COL=CPT_CODE
PRICEMEDIC_PAYER_COL=PAYER_NAME
# Row count of the working sample materialized at the top of the example /
# integration test. Default is 500_000 for the example, 200_000 for tests.
# Set lower for faster runs or higher for richer aggregates.
# PRICEMEDIC_SAMPLE_ROWS=500000


# ---------------------------------------------------------------------------
# Postgres connection (for the Cornerstone integration tests + example).
# Same pattern: copy to `.env`, fill values, `set -a; source .env; set +a`.
# DO NOT commit the `.env` — it stays out of git.
# ---------------------------------------------------------------------------
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSL_MODE=require
# POSTGRES_CONNECT_TIMEOUT=30

# Cornerstone Learning table + column mapping.
#
# `materialize_sample()` builds an explicit projection that aliases every
# source column to its lowercase name in the temp table. That means downstream
# env vars below can be bare lowercase identifiers regardless of how the
# source columns are cased in Postgres — no shell-quoting needed.
#
# The source table itself is auto-quoted by the runner, so this works as-is:
CORNERSTONE_TABLE=public.transcript_csod
CORNERSTONE_SCORE_COL=score
CORNERSTONE_TIME_COL=completiondate
CORNERSTONE_STATUS_COL=trainingstatus
CORNERSTONE_USER_COL=userid
CORNERSTONE_ACTIVITY_COL=loid
# Row count of the working sample. Default 100_000.
# CORNERSTONE_SAMPLE_ROWS=100000


# ---------------------------------------------------------------------------
# AWS / S3 (shared by the Delta-Lake and Iceberg sources). DuckDB's `aws`
# extension reads these via the standard credential chain — set them here,
# leave them in your shell profile, or rely on an IAM instance/task role.
# Required:  AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION
# Optional:  AWS_SESSION_TOKEN (STS), AWS_PROFILE (~/.aws/credentials profile)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# AWS_SESSION_TOKEN=
# AWS_PROFILE=

# Delta Lake table on S3. Point at the root of the Delta table directory
# (the folder containing `_delta_log/`). The recipe references it as
# `params["table"]` = `facts` (DuckDB VIEW name registered by the executor).
DELTA_TABLE_S3_PATH=
# Column mapping into the recipe's standard params.
DELTA_RATE_COL=metric_val
DELTA_DATE_COL=metric_ts
DELTA_GROUP_COL=entity_id
# Row count to pull through FedSQL. Default 10_000.
# DELTA_SAMPLE_ROWS=10000

# Iceberg table on S3. For direct-path scans, point at the table root or its
# `metadata/v*.metadata.json` file. For catalog-based discovery (Glue, REST),
# install the `lakehouse` extra and switch the executor to use pyiceberg.
ICEBERG_TABLE_S3_PATH=
ICEBERG_RATE_COL=metric_val
ICEBERG_DATE_COL=metric_ts
ICEBERG_GROUP_COL=entity_id
# ICEBERG_SAMPLE_ROWS=10000
